# PostgreSQL Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/food_store_db

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-required-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
DEBUG=True
ENVIRONMENT=development

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Mercado Pago Integration
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_NOTIFICATION_URL=http://localhost:8000/api/v1/pagos/webhook

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_PERIOD=900

# Optional: Email Configuration (for notifications, future feature)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=no-reply@foodstore.com
