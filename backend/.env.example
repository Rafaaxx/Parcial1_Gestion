# PostgreSQL Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:nikolan@localhost:5432/food_store_db

# JWT Authentication
JWT_SECRET_KEY=e843a0349fe7e68906c0d603e80371b160db7645b6b260e0291c8418fd4d53de
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
DEBUG=True
ENVIRONMENT=development

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Mercado Pago Integration
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_NOTIFICATION_URL=http://localhost:8000/api/v1/pagos/webhook

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=memory
RATE_LIMIT_GENERAL_LIMIT=10/10 seconds
RATE_LIMIT_AUTH_LIMIT=5/15 minutes

# Optional: Email Configuration (for notifications, future feature)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=no-reply@foodstore.com
